{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 20,
  "rangeStrategy": "bump",
  "labels": ["dependencies", "automated"],
  "commitMessageAction": "update",
  "commitMessageTopic": "{{groupName}}",
  "commitMessageExtra": "",
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "groupName": "cargo dependencies",
      "commitMessagePrefix": "cargo:",
      "addLabels": ["cargo"],
      "schedule": ["before 6am on monday"]
    },
    {
      "matchManagers": ["cargo"],
      "matchPackageNames": ["crossterm"],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false,
      "description": "crossterm breaks semver — https://github.com/Nukesor/comfy-table/issues/109"
    },
    {
      "matchManagers": ["npm"],
      "matchFileNames": ["late-web/**"],
      "groupName": "npm dependencies",
      "commitMessagePrefix": "npm:",
      "addLabels": ["npm"],
      "schedule": ["before 6am on monday"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions dependencies",
      "commitMessagePrefix": "github:",
      "addLabels": ["github-actions"],
      "schedule": ["before 6am on the first day of the month"]
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "docker dependencies",
      "commitMessagePrefix": "docker:",
      "addLabels": ["docker"],
      "schedule": ["before 6am on the first day of the month"]
    },
    {
      "matchManagers": ["nix"],
      "groupName": "nix dependencies",
      "commitMessagePrefix": "nix:",
      "addLabels": ["nix"],
      "schedule": ["before 6am on monday"]
    }
  ]
}
